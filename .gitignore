node_modules/
.pnp

# Build
dist/
build/
out/

# Bundle stats (gerado por rollup-plugin-visualizer)
stats.html
dist/stats.html

# Rust (GRANDE - nunca commitar)
target/
src-tauri/target/

# Sidecar compilado
sidecar/dist/

# Binarios de media reais (NUNCA commitar - descarregar com npm run download:binaries)
