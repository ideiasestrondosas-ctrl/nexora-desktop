{
  "name": "nexora-desktop",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "sidecar:check": "tsc --noEmit --project sidecar/tsconfig.json",
    "sidecar:build": "esbuild sidecar/index.ts --bundle --platform=node --target=node20 --external:better-sqlite3 --outfile=sidecar/dist/nexora-sidecar.js",
    "sidecar:dev": "tsx watch sidecar/index.ts"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "better-sqlite3": "^12.9.0",
    "concurrently": "^9.2.1",
    "esbuild": "^0.28.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
