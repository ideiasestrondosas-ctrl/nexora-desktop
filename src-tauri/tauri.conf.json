{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nexora Desktop",
  "version": "0.22.0",
  "identifier": "com.nexora.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Nexora Desktop",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "center": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "\u0027self\u0027",
        "img-src": "\u0027self\u0027 asset: data: blob: https://asset.localhost",
        "media-src": "\u0027self\u0027 asset: data: blob:",
        "connect-src": "\u0027self\u0027 ipc: http://ipc.localhost",
        "script-src": "\u0027self\u0027",
        "style-src": "\u0027self\u0027 \u0027unsafe-inline\u0027",
        "font-src": "\u0027self\u0027 data:"
      },
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "msi", "nsis", "dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/ffmpeg", "binaries/ffprobe"],
    "resources": ["../sidecar/dist/nexora-sidecar.cjs", "resources/vmaf_models"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEEyQzJBMTQ4NTkxNzc1NTgKUldSWWRSZFpTS0hDb25jNWVPbGJSQnlDeFo4YnFFT2JHb1BFNFR3MDJ0ckk0ZUs5ODQrcG4veFMK",
      "endpoints": [
        "https://github.com/ideiasestrondosas-ctrl/nexora-desktop/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
