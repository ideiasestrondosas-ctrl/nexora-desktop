{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Nexora Desktop",
    "version": "0.4.0",
    "identifier": "com.nexora.desktop",
    "build": {
        "beforeDevCommand": "npm run dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "npm run build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "label": "main",
                "title": "Nexora Desktop",
                "width": 1280,
                "height": 800,
                "minWidth": 900,
                "minHeight": 600,
                "center": true,
                "dragDropEnabled": false
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "externalBin": [
            "binaries/ffmpeg",
            "binaries/ffprobe"
        ],
        "resources": [
            "../sidecar/dist/nexora-sidecar.cjs"
        ]
    },
    "plugins": {
        "updater": {
            "pubkey": "",
            "endpoints": [
                "https://github.com/ideiasestrondosas-ctrl/nexora-desktop/releases/latest/download/latest.json"
            ],
            "dialog": true,
            "windows": {
                "installMode": "passive"
            }
        }
    }
}