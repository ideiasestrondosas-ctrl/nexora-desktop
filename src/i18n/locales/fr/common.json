    "intro": {
      "whatIs": "What is Nexora Desktop?",
      "description": "Nexora Desktop is a native multiplatform application for professional media processing. It brings the power of the Nexora server pipeline directly to your workstation, with zero cloud dependencies.",
      "features": {
        "offline": "Fully offline processing — no internet required",
        "broadcast": "Broadcast-compliant profiles (BBC, Netflix, DPP)",
        "gpu": "GPU acceleration (NVENC, AMF, QSV)",
        "vmaf": "Active VMAF quality scoring with per-profile thresholds"
      },
      "architecture": "Built with Tauri 2.x (Rust) for the native shell, React 19 for the UI, and a Node.js sidecar for media orchestration. SQLite stores all metadata locally."
    },
    "usage": {
      "workflow": "Workflow",
      "steps": {
        "1": "Add media via drag & drop or file dialog",
        "2": "Select a transcode profile (broadcast-hd, web-4k, etc.)",
        "3": "Submit to the queue — jobs process automatically",
        "4": "Review QC reports and approve/reject quarantined items",
        "5": "Access processed files in the output folder"
      },
      "tips": "Tips",
      "tipsList": {
        "1": "Use GPU acceleration for 5-10x faster transcodes",
        "2": "Enable notifications to get alerts when jobs finish",
        "3": "Check the Logs page for detailed FFmpeg output",
        "4": "Factory Reset wipes everything — use with caution"
      }
    },
    "profiles": {
