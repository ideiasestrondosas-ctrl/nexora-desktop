        "vmafDesc": "Perceptual quality score 0-100 for each job",
        "profiles": "6 Profiles",
        "profilesDesc": "Broadcast HD/SD, Web HD/4K, Social, Proxy",
        "gpuAuto": "Auto GPU",
        "gpuAutoDesc": "Automatic detection of NVIDIA, AMD and Intel"
      },
      "architecture": "Built with Tauri 2.x (Rust) for the native shell, React 19 for the UI, and a Node.js sidecar for media orchestration. SQLite stores all metadata locally."
